# Zadarma API (Settings → Integrations and API)
ZADARMA_API_KEY=
ZADARMA_API_SECRET=

# Espera antes de descargar la grabación (ms). Zadarma recomienda ~40 s.
RECORD_DOWNLOAD_DELAY_MS=40000

# Google Drive (OAuth2 — cuenta personal)
# Genera las credenciales en Google Cloud Console → APIs & Services → Credentials
# → Create Credentials → OAuth client ID → Desktop app
# Luego intercambia el code por un refresh token (ver README).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=

# Servidor
PORT=3000
